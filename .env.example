# banquito-switch-on-us-settlement-service environment example
SERVER_PORT=8083

DB_URL=jdbc:postgresql://postgres:5432/SWITCH_LIQUIDACION_ON_US_DB
DB_USERNAME=postgres
DB_PASSWORD=postgres

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

RABBIT_EXCHANGE_ROUTING=switch.routing.exchange
RABBIT_EXCHANGE_SETTLEMENT=switch.settlement.exchange
RABBIT_QUEUE_SETTLEMENT_ON_US=switch.settlement.on-us.queue
RABBIT_QUEUE_SETTLEMENT_COMPLETED=switch.settlement.completed.queue
RABBIT_ROUTING_KEY_ROUTED_ON_US=payment.line.routed.on-us
RABBIT_ROUTING_KEY_ON_US_COMPLETED=payment.line.on-us.completed
RABBIT_ROUTING_KEY_LINE_REJECTED=payment.line.rejected

# Deprecated legacy Core gRPC settings
CORE_GRPC_HOST=core-banking-mock
CORE_GRPC_PORT=9090
CORE_GRPC_DEADLINE_MS=60000

# Core REST via Kong/API Manager
CORE_KONG_BASE_URL=http://localhost:8000
CORE_KONG_SWITCH_CORE_PATH=/api/v1/switch-core
CORE_KONG_PAYMENT_RESERVATIONS_PATH=/payment-reservations
CORE_KONG_AUTH_TOKEN=
CORE_KONG_CLIENT_TOKEN_ENABLED=true
CORE_KONG_CLIENT_ID=switch-pagos-internos-service
CORE_KONG_CLIENT_SECRET=
CORE_KONG_REQUIRED_SCOPE=core.reserve.consume
CORE_KONG_CLIENT_TOKEN_PATH=/api/v1/auth/client-token
CORE_KONG_CLIENT_TOKEN_REFRESH_SKEW_SECONDS=60
CORE_KONG_CONNECT_TIMEOUT_MS=5000
CORE_KONG_READ_TIMEOUT_MS=30000
CORE_SWITCH_DEFAULT_ACCOUNTING_DATE=
